{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cegel Print Bridge",
  "version": "0.1.0",
  "identifier": "app.cegel.printbridge",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cegel Print Bridge",
        "width": 480,
        "height": 560,
        "resizable": false,
        "visible": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Daemon local para imprimir tickets ESC/POS desde la app de Cegel.",
    "longDescription": "Cegel Print Bridge corre en segundo plano en tu equipo, recibe los trabajos de impresión enviados por la app web (www.cegel.app) y los entrega a la impresora térmica conectada por USB, red o serial. También acciona el cajón monedero.",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/CesarPuerta/print-bridge/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE3MTZDMzc5NjM1NDIyMTAKUldRUUlsUmplY01XcDhRWUFLSThRRDI5RjI2YTZwTW91ZEtHYkhDWGhBalpYRzd2dWRCQURXNWgK"
    }
  }
}
